"""
scripts/fix_catalog.py
Fixes invalid control characters in catalog_raw.json that cause
json.decoder.JSONDecodeError.

Run this ONCE before build_index:
    python -m scripts.fix_catalog
"""

import re
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).parent.parent
INPUT  = PROJECT_ROOT / "data" / "catalog_raw.json"
BACKUP = PROJECT_ROOT / "data" / "catalog_raw.backup.json"

def fix_control_chars(text: str) -> str:
    """
    Remove or replace ASCII control characters that are illegal inside
    JSON strings (U+0000–U+001F except tab/newline/carriage-return).
    """
    # Replace literal \r\n or \r with a space (common from Windows copy-paste)
    text = text.replace('\r\n', ' ').replace('\r', ' ')

    # Remove remaining control chars except \t (0x09) \n (0x0A)
    # These are the ones JSON spec forbids inside string values
    text = re.sub(r'[\x00-\x08\x0b\x0c\x0e-\x1f]', ' ', text)

    return text

def main():
    if not INPUT.exists():
        print(f"ERROR: {INPUT} not found.")
        sys.exit(1)

    print(f"Reading {INPUT} …")
    raw = INPUT.read_bytes().decode("utf-8", errors="replace")

    print("Fixing control characters …")
    fixed = fix_control_chars(raw)

    # Quick validation
    import json
    try:
        parsed = json.loads(fixed)
        print(f"✓ JSON valid after fix — {len(parsed)} items.")
    except json.JSONDecodeError as e:
        print(f"✗ Still invalid after fix: {e}")
        print("  Try opening the file in VS Code and re-saving as UTF-8.")
        sys.exit(1)

    # Back up original
    BACKUP.write_text(raw, encoding="utf-8")
    print(f"  Original backed up to {BACKUP.name}")

    # Overwrite with fixed version
    INPUT.write_text(fixed, encoding="utf-8")
    print(f"✓ Fixed catalog saved to {INPUT.name}")
    print("\nNow run:  python -m scripts.build_index")

if __name__ == "__main__":
    main()